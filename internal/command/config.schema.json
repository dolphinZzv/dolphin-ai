{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Dolphin Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "lang": {
      "description": "Language for UI and messages",
      "type": "string",
      "default": "en"
    },
    "llm": {
      "description": "LLM provider and model configuration. Known fields listed below; any other key is treated as a provider section (e.g. deepseek_anthropic, deepseek_openai).",
      "type": "object",
      "properties": {
        "use": { "type": "string", "description": "Active model name (references a model from any provider's model list)" },
        "max_tokens": { "type": "integer", "minimum": 1, "default": 4096 },
        "max_retries": { "type": "integer", "minimum": 0, "default": 3 },
        "timeout": { "type": "string", "pattern": "^\\d+[smh]$", "description": "Request timeout, e.g. 30s, 5m" },
        "limit": {
          "type": "object",
          "description": "Global usage limits",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "max_requests": { "$ref": "#/definitions/limitValue", "description": "Max LLM requests per cycle" },
            "max_total_tokens": { "$ref": "#/definitions/limitValue", "description": "Max total tokens per cycle" },
            "max_input_tokens": { "$ref": "#/definitions/limitValue", "description": "Max input tokens per cycle" },
            "max_output_tokens": { "$ref": "#/definitions/limitValue", "description": "Max output tokens per cycle" },
            "reset_cron": { "type": "string", "description": "Cron expression for counter reset, e.g. 0 0 * * *" }
          }
        }
      },
      "additionalProperties": { "$ref": "#/definitions/providerSection" }
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"], "default": "info" },
        "file": { "type": "string", "description": "Log file path" },
        "max_size": { "type": "integer", "description": "Max log file size in MB", "default": 100 },
        "max_backups": { "type": "integer", "default": 30 },
        "max_age": { "type": "integer", "description": "Max days to retain logs", "default": 30 },
        "compress": { "type": "boolean", "default": true },
        "rotate_interval": { "type": "string", "pattern": "^\\d+[smh]$", "description": "Log rotation interval, e.g. 24h" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout": { "type": "string", "pattern": "^\\d+[smh]$", "default": "30s" }
      }
    },
    "compaction": {
      "type": "object",
      "additionalProperties": false,
      "description": "Auto-compaction summarizes old messages when the estimated token count exceeds max_tokens.",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "max_tokens": { "type": "integer", "minimum": 1, "default": 60000, "description": "Token threshold that triggers auto-compaction. Shown in TUI status bar as tok:N/60k(X%)." },
        "keep_rounds": { "type": "integer", "minimum": 1, "default": 6, "description": "Recent rounds kept verbatim when compacting." },
        "model": { "type": "string", "description": "Model used to generate the compact summary (empty = active model)." },
        "summary_max_tokens": { "type": "integer", "default": 512 },
        "token_ratio": { "type": "integer", "default": 4, "description": "Runes per estimated token for token counting." }
      }
    },
    "dream": {
      "type": "object",
      "additionalProperties": false,
      "description": "Offline self-edit system that scans recent sessions after user inactivity and applies improvements to brain files on a git branch.",
      "properties": {
        "enabled": { "type": "boolean", "default": true, "description": "Enable the offline self-editing system. Set to false to disable all dream runs." },
        "idle_minutes": { "type": "integer", "minimum": 0, "default": 20, "description": "Minutes of user inactivity before dream triggers. 0 disables idle-triggered dreams (but /dream now still works)." },
        "exit_idle_minutes": { "type": "integer", "minimum": 1, "default": 2, "description": "Accelerated idle window after /exit command. Dream waits this many minutes instead of idle_minutes." },
        "auto_apply": { "type": "boolean", "default": true, "description": "Auto-merge dream edits to main branch. false = create branch and wait for /dream review." },
        "min_sessions": { "type": "integer", "minimum": 0, "default": 2, "description": "Minimum new sessions since last dream to trigger Phase 0 gate." },
        "min_user_messages": { "type": "integer", "minimum": 0, "default": 8, "description": "Minimum user messages in new sessions to trigger Phase 0 gate." },
        "max_consecutive_empty": { "type": "integer", "minimum": 1, "default": 3, "description": "Maximum consecutive empty dream runs before the gate requires more sessions." },
        "min_impact_threshold": { "type": "number", "minimum": 0, "default": 0.5, "description": "Edits below this impact score skip Phase 2 LLM and go through rule-only processing." },
        "file_cooldown_dreams": { "type": "integer", "minimum": 0, "default": 5, "description": "Number of dream runs before the same file can be edited again. Prevents repeated editing loops." },
        "max_edits_per_dream": { "type": "integer", "minimum": 1, "default": 10, "description": "Maximum edit proposals per dream run. Extra proposals are truncated." },
        "calibration_window": { "type": "integer", "minimum": 1, "default": 10, "description": "Sliding window size for Phase 4 calibration adopt-rate tracking." },
        "calibration_min_step": { "type": "number", "minimum": 0.01, "default": 0.05, "description": "Minimum threshold adjustment step in calibration. Prevents oscillation." },
        "calibration_confidence_floor": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3, "description": "Lowest allowed confidence threshold after calibration adjustments." },
        "calibration_confidence_ceiling": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.95, "description": "Highest allowed confidence threshold after calibration adjustments." },
        "reflect_model": { "type": "string", "description": "Model used for Phase 2 LLM reflection. Empty = active model." },
        "max_reflect_tokens": { "type": "integer", "minimum": 1, "default": 2048, "description": "Maximum output tokens for Phase 2 LLM call." }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": { "type": "string", "default": ".dolphin/sessions" },
        "type": { "type": "string", "enum": ["file", "sqlite", "wal"], "default": "file", "description": "Session storage backend: file (JSON) or sqlite or wal(append-only). DB at {dir}/memory.db" },
        "dump_dir": { "type": "string", "default": ".dolphin/dumps", "description": "Directory where /dump writes turn JSON dumps." },
        "window": { "type": "integer", "minimum": 1, "default": 40 },
        "expire_after": {
          "type": "string",
          "default": "1h",
          "description": "Idle duration after which a new turn prompts the user to start a fresh session. Go duration syntax (e.g. 1h, 30m). Set to 0 to disable."
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "default": "Dolphin" },
        "max_rounds": { "type": "integer", "minimum": 1, "default": 100 },
        "pool_size": { "type": "integer", "minimum": 1, "default": 1 },
        "tool_parallelism": { "type": "integer", "minimum": 1, "default": 1, "description": "Max parallel tool calls per turn" },
        "buffer_size": { "type": "integer", "default": 1024 },
        "turn_timeout": { "type": "string", "pattern": "^\\d+[smh]$", "default": "120s", "description": "Per-round hard cap. Each loop round (LLM + tools) gets a fresh budget of this size." },
        "llm_idle_timeout": { "type": "string", "pattern": "^(0|\\d+[smh])$", "default": "60s", "description": "Watchdog idle window. The turn is cancelled if no LLM chunk or tool result arrives within this window. 0 disables the watchdog." },
        "feed_min_interval": { "type": "string", "pattern": "^(0|\\d+(ns|us|µs|ms|s|m|h))$", "default": "100ms", "description": "Throttle window for watchdog Feed calls. Feed calls closer than this to the previous effective feed are no-ops, so hot paths (per-chunk, per-line) can call Feed freely. 0 disables throttling." },
        "bin": { "type": "string", "description": "Directory path added to PATH for shell commands (CLI tools)" },
        "workspace": { "type": "string", "default": "." },
        "workmode": { "type": "string", "enum": ["default", "yolo"], "default": "default" },
        "webhook": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["http", "dingtalk", "wework"], "default": "http" },
            "url": { "type": "string", "format": "uri", "description": "Webhook URL for limit alerts" }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "description": "Agent mesh multi-agent collaboration configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false, "description": "Enable the agent mesh layer" },
        "name": { "type": "string", "description": "This agent's name in the mesh" },
        "listen_addr": { "type": "string", "default": ":8100", "description": "A2A HTTP server listen address" },
        "capabilities": { "type": "array", "items": { "type": "string" }, "description": "Declared capabilities, e.g. [\"code-review\", \"golang\"]" },
        "task_timeout": { "type": "string", "pattern": "^\\d+[smh]$", "default": "10m", "description": "Default timeout for delegated tasks" },
        "max_delegation_depth": { "type": "integer", "minimum": 1, "default": 5 },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_retries": { "type": "integer", "minimum": 0, "default": 2 },
            "backoff": { "type": "string", "pattern": "^(0|\\d+(ns|us|µs|ms|s|m|h))$", "default": "1s" },
            "max_backoff": { "type": "string", "pattern": "^\\d+[smh]$", "default": "30s" }
          }
        },
        "fallback": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "max_fallback": { "type": "integer", "minimum": 0, "default": 2, "description": "Max fallback candidates (excluding primary)" }
          }
        },
        "circuit_breaker": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "failure_threshold": { "type": "integer", "minimum": 1, "default": 5 },
            "cooldown_period": { "type": "string", "pattern": "^\\d+[smh]$", "default": "60s" },
            "half_open_max": { "type": "integer", "minimum": 1, "default": 1 }
          }
        },
        "rate_limit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "send_per_agent": { "type": "number", "minimum": 0, "default": 2, "description": "Requests per second per target agent" },
            "send_burst": { "type": "integer", "minimum": 1, "default": 5 }
          }
        },
        "spawner": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "bin": { "type": "string", "description": "Path to the dolphin binary for spawning child agents" },
            "max_spawned": { "type": "integer", "minimum": 0, "default": 5 }
          }
        },
        "local": {
          "type": "array",
          "description": "Statically configured same-host peer agents",
          "items": { "$ref": "#/definitions/remoteAgent" }
        },
        "remote": {
          "type": "array",
          "description": "Statically configured remote peer agents",
          "items": { "$ref": "#/definitions/remoteAgent" }
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "ca_cert": { "type": "string", "description": "CA certificate file path" },
            "client_cert": { "type": "string", "description": "Client certificate file path" },
            "client_key": { "type": "string", "description": "Client key file path" },
            "insecure_skip_verify": { "type": "boolean", "default": false, "description": "Skip TLS verification (testing only)" }
          }
        }
      }
    },
    "brain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": { "type": "string", "default": ".dolphin/brain" }
      }
    },
    "otel": {
      "type": "object",
      "description": "OpenTelemetry configuration",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "endpoint": { "type": "string", "format": "uri" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "a2a": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "addr": { "type": "string", "default": ":8100", "description": "Listen address for A2A HTTP server" },
        "name": { "type": "string", "description": "Agent name (defaults to agent.name)" },
        "description": { "type": "string", "description": "Agent description for the agent card" },
        "url": { "type": "string", "description": "Agent URL for the agent card" },
        "version": { "type": "string", "description": "Agent version" }
      }
    },
    "dingtalk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "agent_id": { "type": "string" },
        "app_id": { "type": "string" },
        "client_id": { "type": "string" },
        "client_secret": { "type": "string" },
        "webhook_url": { "type": "string", "format": "uri" },
        "allow_users": { "type": "array", "items": { "type": "string" } }
      }
    },
    "wework": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "bot_id": { "type": "string" },
        "bot_secret": { "type": "string" },
        "allow_users": { "type": "array", "items": { "type": "string" } }
      }
    },
    "panda": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "server": { "type": "string", "format": "uri" },
        "account": { "type": "string" },
        "password": { "type": "string" },
        "allow_users": { "type": "array", "items": { "type": "string" } },
        "allow_convs": { "type": "array", "items": { "type": "string" } },
        "at_mention": { "type": "boolean", "default": false, "description": "If true, only process messages that @mention the agent name" }
      }
    },
    "prometheus": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "mode": { "type": "string", "enum": ["pull", "push", "both"], "default": "pull", "description": "pull = /metrics endpoint, push = Remote Write, both = both modes" },
        "addr": { "type": "string", "default": ":9090", "description": "Listen address for /metrics endpoint (pull mode)" },
        "remote_url": { "type": "string", "description": "Prometheus Remote Write URL (push mode)" },
        "push_job": { "type": "string", "default": "dolphin", "description": "Job name for Pushgateway" }
      }
    },
    "pprof": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "addr": { "type": "string", "description": "Listen address for pprof HTTP server, e.g. :6060" }
      }
    },
    "stdio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true, "description": "Enable stdio transport. Set to false when using tui." }
      }
    },
    "tui": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "theme": {
          "type": "object",
          "description": "Custom TUI theme. `active` selects a named theme under `themes`; each theme has light/dark palettes auto-selected by terminal background.",
          "additionalProperties": false,
          "properties": {
            "active": { "type": "string", "default": "default" },
            "themes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "light": {
                    "type": "object",
                    "description": "Light-terminal palette. Colors accept hex (#rrggbb), ANSI 256 numbers, or named colors. Empty fields fall back to the default theme.",
                    "additionalProperties": false,
                    "properties": {
                      "user_message": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "tool_use": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "tool_result": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "thinking": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "response": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "background": { "type": "string", "description": "Whole-TUI background. \"default\" or empty = follow terminal." }
                    }
                  },
                  "dark": {
                    "type": "object",
                    "description": "Dark-terminal palette. Colors accept hex (#rrggbb), ANSI 256 numbers, or named colors. Empty fields fall back to the default theme.",
                    "additionalProperties": false,
                    "properties": {
                      "user_message": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "tool_use": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "tool_result": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "thinking": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "response": { "type": "object", "properties": { "fg": { "type": "string" }, "bg": { "type": "string" } }, "additionalProperties": false },
                      "background": { "type": "string", "description": "Whole-TUI background. \"default\" or empty = follow terminal." }
                    }
                  }
                }
              }
            }
          }
        },
        "show_tools": { "type": "boolean", "default": false },
        "show_thinking": { "type": "boolean", "default": false },
        "history_file": { "type": "string", "description": "Path to input history file" },
        "history_auto_restore": { "type": "boolean", "default": false, "description": "Auto-restore conversation history from the previous session on TUI startup" }
      }
    },
    "email": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "address": { "type": "string", "description": "Email address for sending" },
        "password": { "type": "string" },
        "imap_server": { "type": "string" },
        "imap_port": { "type": "string" },
        "smtp_server": { "type": "string" },
        "smtp_port": { "type": "string" },
        "allow_senders": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mcp_servers": {
      "type": "array",
      "description": "MCP server configurations",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "description": "builtin, stdio, or http" },
          "enabled": { "type": "boolean", "default": true },
          "url": { "type": "string", "format": "uri", "description": "URL for http transport (SSE endpoint)" },
          "command": { "type": "string", "description": "Command for stdio transport" },
          "args": { "type": "array", "items": { "type": "string" }, "description": "Arguments for stdio transport" },
          "headers": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Custom HTTP headers sent with every request" }
        },
        "required": ["name", "type"]
      }
    }
  },
  "definitions": {
    "limitValue": {
      "description": "Limit can be a scalar (hard only) or {hard, soft} object. Supports human-readable suffixes: 1k, 2.5m, 1b.",
      "oneOf": [
        { "type": "integer", "minimum": 1 },
        { "type": "string", "pattern": "^\\d+(\\.\\d+)?[kKmMbBtT]?$", "description": "Human-readable count, e.g. 1k, 2.5m, 1b" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hard": { "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string", "pattern": "^\\d+(\\.\\d+)?[kKmMbBtT]?$" }
            ]},
            "soft": { "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string", "pattern": "^\\d+(\\.\\d+)?[kKmMbBtT]?$" }
            ]}
          }
        }
      ]
    },
    "providerSection": {
      "description": "Dynamic LLM provider section (e.g. deepseek_anthropic, deepseek_openai)",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "description": "Vendor name, e.g. deepseek, openai, anthropic" },
        "api_type": { "type": "string", "description": "API protocol type, e.g. openai, anthropic" },
        "api_key": { "type": "string", "description": "API key for the provider" },
        "base_url": { "type": "string", "format": "uri", "description": "API base URL" },
        "model_discover": { "type": "boolean", "default": false, "description": "Auto-fetch model list from the vendor API. When enabled, the models list is populated automatically, but manually defined models still take precedence." },
        "models": {
          "type": "array",
          "description": "List of models available from this provider",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "description": "Model name" },
              "disabled": { "type": "boolean", "default": false, "description": "When true, the model is excluded from the available models list" },
              "reasoning_effort": { "type": "string", "enum": ["high", "max"], "description": "Reasoning effort level. Anthropic format: output_config.effort. OpenAI format: reasoning_effort." },
              "thinking": { "type": "boolean", "default": false, "description": "Enable extended thinking mode. Anthropic format: thinking block with budget_tokens. OpenAI format: thinking field (provider-dependent)." },
              "stream": { "type": "boolean", "default": true, "description": "Enable SSE streaming for this model" },
              "max_tokens": { "type": "integer", "minimum": 1 },
              "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.7 },
              "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
              "max_retries": { "type": "integer", "minimum": 0 },
              "timeout": { "type": "string", "pattern": "^\\d+[smh]$", "description": "Request timeout, e.g. 30s, 5m" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Per-model custom HTTP headers. Override same-named headers from the section-level llm.<name>.headers; other section headers still apply." },
              "limit": {
                "type": "object",
                "description": "Per-model usage limits",
                "additionalProperties": false,
                "properties": {
                  "max_requests": { "$ref": "#/definitions/limitValue" },
                  "max_total_tokens": { "$ref": "#/definitions/limitValue" },
                  "max_input_tokens": { "$ref": "#/definitions/limitValue" },
                  "max_output_tokens": { "$ref": "#/definitions/limitValue" },
                  "max_concurrency": { "type": "integer", "minimum": 1, "description": "Max concurrent LLM streams for this model" }
                }
              }
            },
            "required": ["name"]
          }
        }
      }
    },
    "remoteAgent": {
      "type": "object",
      "additionalProperties": false,
      "description": "A statically configured peer agent",
      "properties": {
        "name": { "type": "string" },
        "addr": { "type": "string", "description": "host:port of the peer A2A server" },
        "capabilities": { "type": "array", "items": { "type": "string" }, "description": "Declared capabilities" },
        "model": { "type": "string", "description": "LLM model in use" }
      }
    }
  }
}
