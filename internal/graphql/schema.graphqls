scalar Time
scalar Map

enum AgentKind {
  ai
  human
  hybrid
}

enum AgentStatus {
  online
  busy
  offline
  error
}

type Agent {
  id: ID!
  number: Int!
  name: String!
  kind: AgentKind!
  status: AgentStatus!
  externalID: String!
  systemPrompt: String
  deviceInfo: String
  modelInfo: String
  lastIP: String
  capabilities: [String!]
  allowedCIDRs: [String!]
  metadata: Map
  lastSeenAt: Time
  createdAt: Time!
  updatedAt: Time!
  assignedIssues: [IssueAssignee!]
  createdIssues: [Issue!]
}

type LoginResult {
  agent: Agent!
  token: String!
}

type RegisterResult {
  agent: Agent!
  token: String!
}

enum ProjectRole {
  owner
  maintainer
  member
  observer
}

type ProjectMember {
  id: ID!
  number: Int!
  projectID: ID!
  agentID: ID!
  role: ProjectRole!
  agent: Agent!
}

type Project {
  id: ID!
  number: Int!
  name: String!
  description: String
  createdAt: Time!
  updatedAt: Time!
  members: [ProjectMember!]
  labels: [Label!]
  milestones: [Milestone!]
}

enum IssueState {
  open
  in_progress
  blocked
  review
  later
  reopen
  closed_completed
  closed_not_planned
  closed_rejected
}

enum Priority {
  critical
  high
  medium
  low
}

type IssueAssignee {
  id: ID!
  number: Int!
  issueID: ID!
  agentID: ID!
  state: AssigneeState!
  assignedAt: Time!
  agent: Agent!
}

enum AssigneeState {
  pending
  in_progress
  completed
  blocked
}

type Label {
  id: ID!
  number: Int!
  name: String!
  color: String
  description: String
  projectID: ID!
  capability: String
  group: String
}

type Milestone {
  id: ID!
  number: Int!
  projectID: ID!
  title: String!
  description: String
  state: MilestoneState!
  dueDate: Time
  createdAt: Time!
  updatedAt: Time!
}

enum MilestoneState {
  open
  closed
}

type Issue {
  id: ID!
  number: Int!
  projectID: ID!
  title: String!
  description: String
  state: IssueState!
  priority: Priority!
  creatorID: ID!
  parentID: ID
  dueDate: Time
  closedAt: Time
  createdAt: Time!
  updatedAt: Time!
  creator: Agent!
  assignees: [IssueAssignee!]
  labels: [Label!]
  children: [Issue!]
  milestone: Milestone
  structuredOutput: Map
}

enum CommentContentType {
  markdown
  tool_call
  tool_result
  code_diff
  decision
  approval
  rejection
  structured
}

type Comment {
  id: ID!
  number: Int!
  issueID: ID!
  authorID: ID!
  parentID: ID
  body: String!
  contentType: CommentContentType!
  createdAt: Time!
  updatedAt: Time!
  author: Agent!
  parent: Comment
  replies: [Comment!]
}

type TimelineEvent {
  id: ID!
  number: Int!
  issueID: ID!
  actorID: ID!
  eventType: String!
  payload: Map
  createdAt: Time!
  actor: Agent!
}

type IssueConnection {
  edges: [Issue!]!
  total: Int!
}

enum FeedbackTargetType {
  issue
  comment
  agent
  assignment
}

enum FeedbackRating {
  one
  two
  three
  four
  five
}

type Feedback {
  id: ID!
  number: Int!
  targetType: FeedbackTargetType!
  targetID: ID!
  authorID: ID!
  rating: FeedbackRating!
  body: String
  createdAt: Time!
  author: Agent!
}

type Query {
  agents(kind: AgentKind, status: AgentStatus, capabilities: [String!], projectID: ID): [Agent!]!
  agent(id: ID!): Agent
  projects: [Project!]!
  project(id: ID!): Project
  labels(projectID: ID!, group: String): [Label!]!
  milestones(projectID: ID!, state: MilestoneState): [Milestone!]!
  issue(id: ID!): Issue
  issues(projectID: ID!, state: IssueState, priority: Priority, assigneeID: ID, limit: Int, offset: Int): IssueConnection!
  comments(issueID: ID!): [Comment!]!
  timeline(issueID: ID!): [TimelineEvent!]!
  validTransitions(state: IssueState!): [IssueState!]!
  feedback(targetType: FeedbackTargetType!, targetID: ID!): [Feedback!]!
}

type Mutation {
  registerAgent(name: String!, kind: AgentKind!, externalID: String!, secret: String!, capabilities: [String!], deviceInfo: String, modelInfo: String): RegisterResult!
  loginAgent(externalID: String!, secret: String!): LoginResult!
  updateAgentStatus(id: ID!, status: AgentStatus!): Agent!
  updateAgentAllowedCIDRs(id: ID!, allowedCIDRs: [String!]!): Agent!

  createProjectAgent(projectID: ID!, name: String!, kind: AgentKind!, externalID: String, secret: String, capabilities: [String!], deviceInfo: String, modelInfo: String): RegisterResult!

  createProject(name: String!, description: String): Project!
  updateProject(id: ID!, name: String, description: String): Project!
  deleteProject(id: ID!): Boolean!
  addProjectMember(projectID: ID!, agentID: ID!, role: ProjectRole!): ProjectMember!
  updateProjectMember(projectID: ID!, agentID: ID!, role: ProjectRole!): ProjectMember!
  removeProjectMember(projectID: ID!, agentID: ID!): Boolean!

  createIssue(projectID: ID!, title: String!, description: String, priority: Priority!, assigneeIDs: [ID!], labelIDs: [ID!], milestoneId: ID): Issue!
  updateIssue(id: ID!, title: String, description: String, priority: Priority, dueDate: Time, milestoneId: ID): Issue!
  deleteIssue(id: ID!): Boolean!
  transitionIssue(id: ID!, newState: IssueState!, actorID: ID!): Issue!

  addAssignee(issueID: ID!, agentID: ID!): IssueAssignee!
  removeAssignee(issueID: ID!, agentID: ID!): Boolean!
  updateAssigneeState(issueID: ID!, agentID: ID!, state: AssigneeState!): IssueAssignee!

  addComment(issueID: ID!, authorID: ID!, body: String!, contentType: CommentContentType!, parentID: ID): Comment!
  updateComment(id: ID!, body: String!): Comment!
  deleteComment(id: ID!): Boolean!

  addLabels(issueID: ID!, labelIDs: [ID!]!): Issue!
  removeLabels(issueID: ID!, labelIDs: [ID!]!): Issue!
  createLabel(projectID: ID!, name: String!, color: String, capability: String, group: String): Label!
  deleteLabel(id: ID!): Boolean!

  createMilestone(projectID: ID!, title: String!, description: String, dueDate: Time): Milestone!
  deleteMilestone(id: ID!): Boolean!

  createFeedback(targetType: FeedbackTargetType!, targetID: ID!, authorID: ID!, rating: FeedbackRating!, body: String): Feedback!
}

type Subscription {
  issueUpdated(issueID: ID!): Issue!
  agentNotifications(agentID: ID!): NotificationEvent!
  agentStatusChanged: AgentStatusEvent!
}

type NotificationEvent {
  id: ID!
  number: Int!
  notificationType: String!
  issueID: ID
  message: String!
  read: Boolean!
  createdAt: Time!
}

type AgentStatusEvent {
  agentID: ID!
  status: AgentStatus!
  timestamp: Time!
}
