<Window x:Class="Dolphin.WebHost.BlockerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        IsHitTestVisible="True"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        Focusable="False">
    <Border x:Name="Indicator"
            Background="#00000000"
            BorderBrush="#44FF0000"
            BorderThickness="2"
            IsHitTestVisible="True" />
</Window>
