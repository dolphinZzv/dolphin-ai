#!/bin/bash
set -euo pipefail

# Only enforce when there are staged changes.
staged=$(git diff --cached --name-only)
if [ -z "$staged" ]; then
  exit 0
fi

# Check if any staged file is a non-test Go source file.
src_files=$(echo "$staged" | grep '\.go$' | grep -v '_test\.go$' || true)
if [ -z "$src_files" ]; then
  exit 0
fi

# CHANGELOG.md must be staged alongside Go source changes.
if ! echo "$staged" | grep -q '^CHANGELOG\.md$'; then
  echo "ERROR: CHANGELOG.md must be updated when committing Go source changes."
  echo "Staged .go files:"
  echo "$src_files" | sed 's/^/  /'
  echo ""
  echo "Add a line to CHANGELOG.md describing your change, then:"
  echo "  git add CHANGELOG.md && git commit ..."
  exit 1
fi
